// This is your Prisma schema file refactored for SQLite
generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

// -----------------------------------------
// MODELS
// -----------------------------------------

model User {
  id             String        @id @default(uuid())
  name           String
  email          String        @unique
  phone          String        @unique
  passwordHash   String
  role           String        @default("USER") // USER, RESELLER, ADMIN
  profilePicture String?       // URL to cloudinary or base64
  theme          String        @default("DARK") // DARK, LIGHT, SYSTEM
  
  // 2FA Fields
  twoFactorSecret String?
  twoFactorEnabled Boolean     @default(false)

  // Paystack Integration
  paystackCustomerId String?
  psAccountNumber      String?
  psBankName           String?
  psAccountName        String?

  // PaymentPoint Integration
  ppAccountNumber      String?
  ppBankName           String?
  ppAccountName        String?

  // Password Reset
  resetToken           String?
  resetTokenExpiry     DateTime?

  referralCode         String?  @unique @default(uuid())
  referredBy           String?

  // Relations
  wallet         Wallet?
  transactions   Transaction[]
  auditLogs      AuditLog[]
  notifications  Notification[]

  createdAt      DateTime      @default(now())
  updatedAt      DateTime      @updatedAt

  @@map("users")
}

model Wallet {
  id             String        @id @default(uuid())
  userId         String        @unique
  balance        Float         @default(0.00)
  bonusBalance   Float         @default(0.00)

  // Relations
  user           User          @relation(fields: [userId], references: [id], onDelete: Cascade)
  transactions   Transaction[]

  updatedAt      DateTime      @updatedAt

  @@map("wallets")
}

model Transaction {
  id             String            @id @default(uuid())
  userId         String
  walletId       String
  
  amount         Float
  costPrice      Float?            // What the provider charged
  profit         Float?            // The difference (amount - costPrice)
  status         String            @default("PENDING") // PENDING, SUCCESS, FAILED, REFUNDED
  serviceType    String            // DATA, AIRTIME, etc.
  provider       String            // CHEAP_DATA_HUB, VTPASS, etc.
  reference      String            @unique
  description    String?

  // Relations
  user           User              @relation(fields: [userId], references: [id])
  wallet         Wallet            @relation(fields: [walletId], references: [id])

  createdAt      DateTime          @default(now())
  updatedAt      DateTime          @updatedAt

  @@index([userId])
  @@index([reference])
  @@map("transactions")
}

model ServicePrice {
  id             String      @id @default(uuid())
  serviceType    String
  provider       String
  planCode       String      // e.g., 'mtn-1gb'
  
  providerPrice  Float
  sellingPrice   Float
  resellerPrice  Float
  
  isActive       Boolean     @default(true)

  createdAt      DateTime    @default(now())
  updatedAt      DateTime    @updatedAt

  @@unique([provider, planCode])
  @@map("service_prices")
}

model AuditLog {
  id              String      @id @default(uuid())
  userId          String
  
  action          String      // e.g., "CREDIT", "DEBIT"
  amount          Float
  previousBalance Float
  newBalance      Float
  description     String
  
  // Relations
  user            User        @relation(fields: [userId], references: [id])

  createdAt       DateTime    @default(now())

  @@index([userId])
  @@map("audit_logs")
}

model ProviderBalance {
  id        String   @id @default(uuid())
  provider  String   @unique
  balance   Float    @default(0.00)
  updatedAt DateTime @updatedAt

  @@map("provider_balances")
}

model Referral {
  id           String   @id @default(uuid())
  referrerId   String
  referredId   String   @unique
  bonusAmount  Float    @default(100.00)
  status       String   @default("PENDING") // PENDING, PAID
  createdAt    DateTime @default(now())

  @@map("referrals")
}

model Notification {
  id        String   @id @default(uuid())
  userId    String
  title        String
  message      String
  type         String   @default("INFO") // INFO, SUCCESS, WARNING, ERROR
  isRead       Boolean  @default(false)
  replyMessage String?  // User's response
  hasReplied   Boolean  @default(false)
  createdAt    DateTime @default(now())

  // Relations
  user         User     @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId])
  @@map("notifications")
}

model SystemAlert {
  id        String   @id @default(uuid())
  message   String
  isActive  Boolean  @default(false)
  updatedAt DateTime @updatedAt

  @@map("system_alerts")
}
